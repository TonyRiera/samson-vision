{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Samson Vision Pack v1",
  "type": "object",
  "required": [
    "image_type",
    "global_summary",
    "visual_hierarchy",
    "layout_map",
    "ocr_text",
    "objects_and_components",
    "color_map",
    "density_map",
    "ascii_representation",
    "user_actions",
    "uncertainties",
    "do_not_assume",
    "final_interpretation_for_text_only_ai"
  ],
  "properties": {
    "image_type": {"type": "string"},
    "global_summary": {"type": "string"},
    "visual_hierarchy": {"type": "array", "items": {"type": "string"}},
    "layout_map": {"type": "array", "items": {"$ref": "#/$defs/region"}},
    "ocr_text": {"type": "array", "items": {"$ref": "#/$defs/textRegion"}},
    "objects_and_components": {"type": "array", "items": {"$ref": "#/$defs/region"}},
    "color_map": {"type": "array", "items": {"type": "string"}},
    "density_map": {"type": "array", "items": {"type": "string"}},
    "ascii_representation": {"type": "string"},
    "user_actions": {"type": "array", "items": {"type": "string"}},
    "uncertainties": {"type": "array", "items": {"type": "string"}},
    "do_not_assume": {"type": "array", "items": {"type": "string"}},
    "final_interpretation_for_text_only_ai": {"type": "string"}
  },
  "$defs": {
    "box": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {"type": "number", "minimum": 0, "maximum": 100}
    },
    "region": {
      "type": "object",
      "required": ["label", "box", "description"],
      "properties": {
        "label": {"type": "string"},
        "box": {"$ref": "#/$defs/box"},
        "description": {"type": "string"},
        "confidence": {"type": "string", "enum": ["high", "medium", "low"]}
      }
    },
    "textRegion": {
      "type": "object",
      "required": ["text", "box", "confidence"],
      "properties": {
        "text": {"type": "string"},
        "box": {"$ref": "#/$defs/box"},
        "confidence": {"type": "string", "enum": ["high", "medium", "low"]}
      }
    }
  }
}

