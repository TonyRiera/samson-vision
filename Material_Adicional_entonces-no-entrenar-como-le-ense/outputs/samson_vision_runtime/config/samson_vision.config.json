{
  "name": "Samson Vision Runtime",
  "version": "1.0.0",
  "pack_version": "SAMSON_VISION_PACK v1",
  "default_mode": "agent_action",
  "default_domain": "web",
  "domains": ["generic", "photo", "chart", "web", "excel", "spreadsheet", "dashboard", "document", "pdf", "gui", "software"],
  "modes": {
    "fast": "summary + basic layout + OCR",
    "standard": "complete pack",
    "deep": "complete pack + richer uncertainty analysis",
    "agent_action": "complete pack optimized for agent decisions and coordinates"
  },
  "always_retrieve": [
    "00_CORE_RULES.md",
    "01_OUTPUT_SCHEMA.md",
    "11_UNCERTAINTY_AND_ANTI_HALLUCINATION.md",
    "14_VALIDATION_CHECKLIST.md"
  ],
  "validator": {
    "require_header": true,
    "require_all_fields": true,
    "require_normalized_coordinates": true,
    "warn_without_confidence": true,
    "warn_if_actions_lack_coordinates": true
  }
}
